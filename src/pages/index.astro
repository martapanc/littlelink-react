---
import Layout from '@/layouts/Layout.astro';
import LinkButton from '@/components/LinkButton.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import { Image } from 'astro:assets';
import { marked } from 'marked';
import links from '@/data/links.json';
import data from '@/data/data.json';
import type { Link } from '@/types/Link';

const footerHtml = marked.parse(data.footer) as string;
---

<Layout title={data.title} description={data.description}>
  <main class="flex min-h-screen flex-col items-center justify-between p-8 md:px-24 md:py-12">
    <div class="container">
      <div class="column flex flex-col items-center">
        <ThemeToggle />
        <div class="avatar-bg rounded-3xl m-3 overflow-hidden">
          <Image
            src={data.icon}
            alt={data.iconAlt}
            width={240}
            height={240}
            quality={90}
            style="width: 120px; height: 120px; display: block;"
          />
        </div>
        <h1 class="mb-3 text-2xl md:text-3xl" role="heading">{data.title}</h1>
        {(links as Link[]).map((link) => (
          <LinkButton link={link} />
        ))}
        <span class="flex flex-col items-center my-4 mx-2 text-xs md:text-sm">
          <Fragment set:html={footerHtml} />
        </span>
      </div>
    </div>
  </main>
</Layout>
