---
// No frontmatter needed
---

<div class="flex justify-end mb-10 w-full">
  <button
    id="theme-toggle"
    aria-label="Toggle color scheme"
    class="relative inline-flex h-7 w-20 items-center rounded-full
           bg-slate-200 hover:bg-slate-50 active:bg-slate-300
           dark:bg-slate-700 dark:hover:bg-slate-800 dark:active:bg-slate-900
           transition-colors duration-200 cursor-pointer border-0 p-0"
  >
    <span
      id="theme-toggle-thumb"
      class="absolute left-1 inline-block h-5 w-5 rounded-full
             bg-slate-800 dark:bg-slate-200
             transition-transform duration-200
             translate-x-0 dark:translate-x-12"
    ></span>
    <span class="absolute inset-0 flex items-center justify-center
                 text-[10px] font-bold text-slate-600 dark:text-slate-300
                 pointer-events-none select-none">
      <span class="dark:hidden ml-5">Light</span>
      <span class="hidden dark:inline mr-5">Dark</span>
    </span>
  </button>
</div>

<script>
  const button = document.getElementById('theme-toggle');
  button?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    html.classList.remove('dark', 'light');
    html.classList.add(isDark ? 'light' : 'dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });
</script>
